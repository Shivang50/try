def generate_all_modes(input_file):

    log_message(f"\nProcessing file: {input_file}")

    try:

        content = read_file(input_file)

        modes = extract_modes(content)

        if not modes:
            raise RuntimeError("No modes detected")

        base_name = os.path.basename(input_file)
        base_name = base_name.replace(".lib.gz", "").replace(".lib", "")

        is_gz = input_file.endswith(".gz")

        for mode in modes:

            os.makedirs(mode, exist_ok=True)

            filtered = filter_by_mode(content, mode)

            cleaned = remove_mode_definitions(filtered)

            output_file = os.path.join(mode, f"{base_name}_{mode}.lib")

            write_file(output_file, cleaned)

            # Only gzip if input was gz
            if is_gz:
                gzip_file(output_file)
                output_file += ".gz"

            print("Generated:", output_file)

        log_message("Status: SUCCESS")

    except Exception as e:

        log_message("Status: FAILED")
        log_message(f"Reason: {str(e)}")
        log_message(traceback.format_exc())
